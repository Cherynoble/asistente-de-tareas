# Claude API key — only needed once we reach Phase 2 (task extraction)
ANTHROPIC_API_KEY=

# Extraction model (provider-agnostic interface; this is the Claude default)
CLAUDE_MODEL=claude-haiku-4-5

# Path to the local iMessage database (default is the standard macOS location)
CHAT_DB_PATH=

# How far back to import on first run
HISTORY_DAYS=30

# How often to poll chat.db for new iMessages (seconds)
IMESSAGE_POLL_SECONDS=60
